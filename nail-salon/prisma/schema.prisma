generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// 予約
model Reservation {
  id            Int               @id @default(autoincrement())
  customerName  String
  customerEmail String
  customerPhone String
  menuName      String            // microCMSのメニュー名をコピー
  menuPrice     Int
  startAt       DateTime
  endAt         DateTime
  status        ReservationStatus @default(PENDING)
  note          String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum ReservationStatus {
  PENDING    // 仮予約
  CONFIRMED  // 確定
  CANCELLED  // キャンセル
  DONE       // 完了
}

// メニュー
model Menu {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  price       Int
  duration    Int      // 施術時間（分）
  category    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// スライダー画像
model SliderImage {
  id        Int      @id @default(autoincrement())
  fileName  String
  alt       String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ギャラリー画像
model GalleryImage {
  id        Int      @id @default(autoincrement())
  fileName  String
  caption   String?
  width     Int
  height    Int
  createdAt DateTime @default(now())
}

// 管理者（NextAuth用）
model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // bcryptハッシュ
  name      String
  createdAt DateTime @default(now())
}
